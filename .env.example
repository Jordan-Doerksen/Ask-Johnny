# Discord bot token (Developer Portal → your app → Bot → Reset Token)
BOT_TOKEN=paste_your_bot_token_here

# Discord Application ID (Developer Portal → General Information → Application ID)
CLIENT_ID=paste_your_client_id_here

# Groq API key (console.groq.com → API Keys)
GROQ_API_KEY=paste_your_groq_key_here

# Optional: register commands to ONE server for instant updates while testing.
# Leave blank to register globally (can take up to an hour to appear).
GUILD_ID=

# Optional: override the Groq model. Defaults to llama-3.3-70b-versatile.
GROQ_MODEL=
