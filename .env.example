# Discord bot token (Developer Portal → your app → Bot → Reset Token)
BOT_TOKEN=paste_your_bot_token_here

# Discord Application ID (Developer Portal → General Information → Application ID)
CLIENT_ID=paste_your_client_id_here

# Groq API key (console.groq.com → API Keys)
GROQ_API_KEY=paste_your_groq_key_here

# Optional: register commands to ONE server for instant updates while testing.
# Leave blank to register globally (can take up to an hour to appear).
GUILD_ID=

# Optional: override the Groq model. Defaults to llama-3.3-70b-versatile.
GROQ_MODEL=

# Optional: co-launch the fun-police ban-list bot from this same host.
# Leave both blank to NOT launch it. These must be fun-police's OWN token and
# app id (a different Discord application than Johnny) — never reuse Johnny's.
FP_BOT_TOKEN=
FP_CLIENT_ID=

# Optional: daily data backup to Discord. Once a day the bot posts
# data/johnny.json and fun-police/banlist.json so a host wipe can't lose them.
# Set ONE (leave both blank to turn it off):
#   BACKUP_CHANNEL_ID — a PRIVATE channel to post backups to (preferred), or
#   OWNER_ID          — your user id, to receive them as a DM.
# (Discord → Settings → Advanced → Developer Mode, then right-click to copy ids.)
BACKUP_CHANNEL_ID=
OWNER_ID=
